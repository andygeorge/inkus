# Inkus configuration
# This is the only file you need to edit.

# Cluster name (used for Incus resources and VM hostnames)
CLUSTER_NAME=inkus

# Kubernetes version (major.minor)
K8S_VERSION=1.31

# Network configuration
NETWORK_SUBNET=10.0.100.0
NETWORK_CIDR=24
NETWORK_GATEWAY=10.0.100.1
DNS_SERVERS="8.8.8.8,8.8.4.4"

# Node counts
CONTROL_PLANE_COUNT=1
WORKER_COUNT=2

# IP address offsets within the subnet
# Control plane nodes: .10, .11, ...
# Workers: .20, .21, ...
CONTROL_PLANE_IP_START=10
WORKER_IP_START=20

# VM resources
VM_CPUS=2
VM_MEMORY=2GiB
VM_DISK=20GiB

# SSH user created on VMs via cloud-init
SSH_USER=k8s
